# Confluence Cloud / Server credentials for confluence-cli
# Place as `.env` next to the *registered* SKILL.md (per workspace), e.g.:
#   ./.cursor/skills/confluence/.env
#   ~/.cursor/skills/confluence/.env
# Never commit the real .env. Override path with CONFLUENCE_ENV_PATH.

# --- required (direct env config) ---
CONFLUENCE_DOMAIN=company.atlassian.net
CONFLUENCE_API_PATH=/wiki/rest/api
CONFLUENCE_AUTH_TYPE=basic
CONFLUENCE_EMAIL=user@company.com
CONFLUENCE_API_TOKEN=ATATT3x...

# --- optional ---
# CONFLUENCE_PROFILE=default
# CONFLUENCE_READ_ONLY=true
# CONFLUENCE_FORCE_CLOUD=true
# CONFLUENCE_LINK_STYLE=plain

# Scoped Cloud token example (agents / least privilege):
# CONFLUENCE_DOMAIN=api.atlassian.com
# CONFLUENCE_API_PATH=/ex/confluence/<cloud-id>/wiki/rest/api
# CONFLUENCE_AUTH_TYPE=basic
# CONFLUENCE_EMAIL=user@company.com
# CONFLUENCE_API_TOKEN=your-scoped-token

# Data Center / Server:
# CONFLUENCE_API_PATH=/rest/api
# CONFLUENCE_AUTH_TYPE=bearer
# (no email required for bearer)
