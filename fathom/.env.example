# Fathom API credentials (https://fathom.ai — Settings → API).
# Copy to `.env` next to the registered `fathom` SKILL.md (never commit the real .env).
# Resolved via common/skill_home.py -> SkillHome("fathom").env_path()

FATHOM_API_KEY=your-api-key-here

# Optional: default output dir used by download_video.py when run standalone
# OUTPUT_DIR=.
