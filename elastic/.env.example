# Elastic shared credentials for /elastic-installed skills.
# Copy this file to `.env` next to the registered `elastic` skill (never commit the real .env).
# Resolved via common/skill_home.py -> SkillHome("elastic").env_path()

# --- Required: Elasticsearch connection ---
ELASTICSEARCH_URL=https://your-cluster.es.example.com:9200
ELASTICSEARCH_USERNAME=your_username
ELASTICSEARCH_PASSWORD=your_password
ELASTICSEARCH_INSECURE=true
# --- Optional: only needed by some Kibana / Cloud skills ---
# KIBANA_URL=https://your-kibana.example.com
# EC_API_KEY=your_elastic_cloud_api_key
